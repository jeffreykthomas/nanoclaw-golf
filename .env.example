ANTHROPIC_API_KEY=your_anthropic_api_key
ASSISTANT_NAME=Andy
ASSISTANT_HAS_OWN_NUMBER=false
PROFILE_MODEL=claude-sonnet-4-6
PROFILE_MAX_OUTPUT_TOKENS=6000
LOG_LEVEL=info

# Golf / coach credentials
ARCCOS_EMAIL=your-email@example.com
ARCCOS_PASSWORD=your-password
COACH_FIRST_RESULT_TIMEOUT=180000

# Coach app integration
CLAW_SIBLING_TOKEN=dev-claw-token...
COACH_APP_URL=http://127.0.0.1:3000
ENABLE_COACH_AGENT=false
APP_PORT=3100

# Telegram ingress
TELEGRAM_BOT_TOKEN=
# Optional multi-bot override for multiple Telegram entry points.
# Use a comma-separated or newline-separated list of bot tokens.
TELEGRAM_BOT_TOKENS=
# Use tg:<chat_id> for groups and tg:telegram:<bot_username>:<chat_id> for private chats.
TELEGRAM_MIRROR_CHAT_ID=
AUTO_CHECKINS_ENABLED=false
CHECKIN_LOOP_INTERVAL_MS=900000
CHECKIN_MIN_HOURS_SINCE_CHAT=18
CHECKIN_MIN_HOURS_SINCE_LAST_CHECKIN=24
CHECKIN_ALLOWED_HOURS=11,12,17,18,19

# BipBot gateway / ingress integration
BIPBOT_GATEWAY_URL=
BIPBOT_GATEWAY_TOKEN=
BIPBOT_FIREBASE_SERVICE_ACCOUNT_PATH=
# Private BipBot ingress chats should use the owner-qualified Telegram JID format.
BIPBOT_INGRESS_CHAT_JID=
BIPBOT_INGRESS_POLL_INTERVAL=10000

# Git / repo automation
GITHUB_TOKEN=

# Mentors operations / Google Workspace
SERVICE_ACCOUNT_EMAIL=
SERVICE_ACCOUNT_ID=
GOOGLE_IMPERSONATE_EMAIL=
GOOGLE_DRIVE_WRITE_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
GMAIL_SEND_AS=

# YouTube / media publishing
YOUTUBE_TOKEN_JSON=
YOUTUBE_CREDENTIALS_JSON=
ELEVENLABS_API_KEY=

# Ads / analytics
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GA4_PROPERTY_ID=
META_ADS_CREDENTIALS=

# Legacy BipBot / triage workflow compatibility
LINEAR_API_KEY=
TRIAGE_REPOS=
BIPBOT_QA_EMAIL=
BIPBOT_QA_PASSWORD=

# X / browser automation
CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# Runtime tuning
CONTAINER_TIMEOUT=1800000
IDLE_TIMEOUT=1800000
MAX_CONCURRENT_CONTAINERS=5
